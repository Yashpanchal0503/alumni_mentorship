# Backend Environment Variables
# Copy this file to .env and fill in real values

# PostgreSQL connection string from Supabase
# Use the "Session Mode" connection string (port 5432) for DIRECT_URL
# Use the "Transaction Mode" connection string (port 6543) for DATABASE_URL
# If you only have one connection string, use the same value for both

DATABASE_URL="postgresql://postgres:yourpassword@db.xxxx.supabase.co:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:yourpassword@db.xxxx.supabase.co:5432/postgres"

# Secret key used to sign JWT tokens — use any long random string
JWT_SECRET="change-this-to-a-very-long-random-secret-string-2026"

# The URL of your deployed frontend (used for CORS)
FRONTEND_URL="https://your-app-name.vercel.app"

# Port (Render sets this automatically, leave as 5000 for local dev)
PORT=5000

# Environment
NODE_ENV=production
